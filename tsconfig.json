{
  "compilerOptions": {
    /* Core */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],

    /* Structure */
    "rootDir": "./src",
    "outDir": "./dist",
    "removeComments": true,

    /* Strictness (max safety) */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Output quality */
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmitOnError": true,

    /* Features */
    "resolveJsonModule": true,

    /* Debugging (disable in prod builds if needed) */
    "sourceMap": false,

    /* Performance */
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo",

    /* Node */
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
